@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="text-danger display-4">¡Oops! Ha ocurrido un error.</h1>
        <h3 class="text-danger mb-4">Lo sentimos, algo salió mal al procesar tu solicitud.</h3>

        @if (!string.IsNullOrEmpty(Model?.RequestId))
        {
            <p>
                <strong>ID de la solicitud:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <div class="alert alert-warning mt-4">
            <h5>Modo Desarrollo</h5>
            <p>
                Cambiar al <strong>entorno de Desarrollo</strong> mostrará más información detallada sobre el error.
            </p>
            <p>
                <strong>No habilites Desarrollo en producción.</strong> Podría mostrar información sensible de la aplicación.
            </p>
            <p>
                Para depuración local, establece la variable <code>ASPNETCORE_ENVIRONMENT=Development</code> y reinicia la app.
            </p>
        </div>

        <a href="~/" class="btn btn-primary mt-3">Volver al inicio</a>
    </div>
</div>

@model Web.Models.CambioClaveViewModel

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Cambio de Clave</h5>
        </div>

        <div class="card-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }
            <form asp-action="CambiodeClave" method="post" novalidate>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nueva clave</label>
                        <input asp-for="NuevaClave" id="NuevaClave" type="password" class="form-control" />
                        <div class="invalid-feedback">
                            Debes ingresar una clave.
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Confirmar clave</label>
                        <input asp-for="ConfirmarClave" id="ConfirmarClave" type="password" class="form-control" />
                        <div class="invalid-feedback">
                            Las contraseñas no coinciden.
                        </div>
                    </div>

                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-success">
                        Guardar clave
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>

<!-- 🔥 TOAST -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1055;">
    <div id="toastSuccess" class="toast align-items-center text-bg-success border-0">
        <div class="d-flex">
            <div class="toast-body">
                ✔ @TempData["Mensaje"]
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
<script>
document.addEventListener("DOMContentLoaded", function () {

    var mensaje = '@TempData["Mensaje"]';

    if (mensaje && mensaje !== '') {
        var toastEl = document.getElementById('toastSuccess');
        var toast = new bootstrap.Toast(toastEl, { delay: 3000 });
        toast.show();
    }

    const form = document.querySelector("form");
    const clave = document.getElementById("NuevaClave");
    const confirmar = document.getElementById("ConfirmarClave");

    function setError(input, message) {
        input.classList.add("is-invalid");
        input.nextElementSibling.innerText = message;
    }

    function clearError(input) {
        input.classList.remove("is-invalid");
    }

    function validar() {

        let valido = true;

        clearError(clave);
        clearError(confirmar);

        // ❌ vacío clave
        if (!clave.value) {
            setError(clave, "Debes ingresar una clave.");
            valido = false;
        }

        // ❌ vacío confirmar
        if (!confirmar.value) {
            setError(confirmar, "Debes confirmar la clave.");
            valido = false;
        }

        // ❌ no coinciden
        if (clave.value && confirmar.value && clave.value !== confirmar.value) {
            setError(confirmar, "Las contraseñas no coinciden.");
            valido = false;
        }

        return valido;
    }

    clave.addEventListener("input", validar);
    confirmar.addEventListener("input", validar);

    form.addEventListener("submit", function (e) {

        if (!validar()) {
            e.preventDefault();
            e.stopImmediatePropagation(); // 🔥 MÁS FUERTE que stopPropagation
            return false;
        }

    });

});
</script>
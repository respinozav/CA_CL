@model Web.Models.RegisterViewModel

@{
    ViewBag.Title = "Registretion";
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    @Html.Partial("~/Views/Shared/_title_meta.cshtml")
    @Html.Partial("~/Views/Shared/_head_css.cshtml")
</head>
<body>
    <div class="account-pages">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-10">
                    <div class="text-center mb-5">
                        <a href="/" class="auth-logo">
                            <img src="~/assets/images/logo-dark.png" alt="Logo Dark" height="28" class="auth-logo-dark">
                            <img src="~/assets/images/logo-light.png" alt="Logo Light" height="28" class="auth-logo-light">
                        </a>
                        <p class="font-size-15 text-muted mt-3">
                            Create your account
                        </p>
                    </div>

                    <div class="card overflow-hidden">
                        <div class="row g-0">
                            <div class="col-lg-6">
                                <div class="p-lg-5 p-4">

                                    <div>
                                        <h5>Register account</h5>
                                        <p class="text-muted">Get your free account now.</p>
                                    </div>

                                    <div class="mt-4 pt-3">

                                        <form asp-action="Registretion" method="post">
                                            @Html.AntiForgeryToken()

                                            @* 🔴 Error *@
                                            @if (!string.IsNullOrEmpty(Model.MensajeError))
                                            {
                                                <div class="alert alert-danger">
                                                    @Model.MensajeError
                                                </div>
                                            }

                                            @* 🟢 OK *@
                                            @if (!string.IsNullOrEmpty(Model.MensajeOk))
                                            {
                                                <div class="alert alert-success">
                                                    @Model.MensajeOk
                                                </div>
                                            }

                                            <div class="mb-3">
                                                <label class="fw-semibold">Email</label>
                                                <input asp-for="Email" class="form-control" placeholder="Enter email" />
                                                <span asp-validation-for="Email" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Username</label>
                                                <input asp-for="Usuario" class="form-control" placeholder="Enter username" />
                                                <span asp-validation-for="Usuario" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Full name</label>
                                                <input asp-for="Nombre" class="form-control" placeholder="Enter your name" />
                                                <span asp-validation-for="Nombre" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Password</label>
                                                <input asp-for="Clave" type="password" class="form-control" placeholder="Enter password" />
                                                <span asp-validation-for="Clave" class="text-danger"></span>
                                            </div>

                                            <div class="mt-4 text-end">
                                                <button class="btn btn-primary w-md waves-effect waves-light" type="submit">
                                                    Register
                                                </button>
                                            </div>

                                            <div class="mt-4 text-center">
                                                <p class="mb-0 text-muted">
                                                    By registering you agree to the Samply
                                                    <a href="#" class="text-primary fw-semibold text-decoration-underline">
                                                        Terms of Use
                                                    </a>
                                                </p>
                                            </div>
                                        </form>

                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="p-lg-5 p-4 bg-auth h-100 d-none d-lg-block">
                                    <div class="bg-overlay"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <p>
                            Already have an account ?
                            <a href="@Url.Action("Login","Authentication")"
                               class="fw-semibold text-decoration-underline">
                                Login
                            </a>
                        </p>
                        <p>
                            © <script>document.write(new Date().getFullYear())</script>
                            <b>Samply</b>. Crafted with
                            <i class="mdi mdi-heart text-danger"></i>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>

    @Html.Partial("~/Views/Shared/_vendor_scripts.cshtml")
</body>
</html>

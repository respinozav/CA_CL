@model Web.Models.RegisterViewModel

@{
    ViewBag.Title = "Registro";
    Layout = null;
}

<!doctype html>
<html lang="es">
<head>
    @Html.Partial("~/Views/Shared/_title_meta.cshtml")
    @Html.Partial("~/Views/Shared/_head_css.cshtml")
</head>
<body>
    <div class="account-pages">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-10">
                    <div class="text-center mb-5">
                        <p class="font-size-15 text-muted mt-3">
                            Crea tu cuenta en ConociendoAmistades.cl
                        </p>
                    </div>

                    <div class="card overflow-hidden">
                        <div class="row g-0">
                            <div class="col-lg-6">
                                <div class="p-lg-5 p-4">

                                    <div>
                                        <h5>Crear cuenta</h5>
                                        <p class="text-muted">Obtén tu cuenta y comienza a conocer nuevas amistades.</p>
                                    </div>

                                    <div class="mt-4 pt-3">

                                        <form asp-action="Registro" method="post">
                                            @Html.AntiForgeryToken()

                                            @* 🔴 Error *@
                                            @if (!string.IsNullOrEmpty(Model.MensajeError))
                                            {
                                                <div class="alert alert-danger">
                                                    @Model.MensajeError
                                                </div>
                                            }

                                            @* 🟢 OK *@
                                            @if (!string.IsNullOrEmpty(Model.MensajeOk))
                                            {
                                                <div class="alert alert-success">
                                                    @Model.MensajeOk
                                                </div>
                                            }

                                            <div class="mb-3">
                                                <label class="fw-semibold">Correo electrónico</label>
                                                <input asp-for="Email" class="form-control" placeholder="Ingresa tu correo electrónico" />
                                                <span asp-validation-for="Email" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Nombre de usuario</label>
                                                <input asp-for="Usuario" class="form-control" placeholder="Crea tu nombre de usuario" />
                                                <span asp-validation-for="Usuario" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Nombre completo</label>
                                                <input asp-for="Nombre" class="form-control" placeholder="Ingresa tu nombre completo" />
                                                <span asp-validation-for="Nombre" class="text-danger"></span>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-semibold">Fecha de nacimiento</label>
                                                <input asp-for="FechaNacimiento" type="date" class="form-control" />
                                                <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Ciudad</label>
                                                <input asp-for="Ciudad" class="form-control" placeholder="¿En qué ciudad vives?" />
                                                <span asp-validation-for="Ciudad" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Género</label>
                                                <select asp-for="Genero" class="form-select">
                                                    <option value="">Selecciona una opción</option>
                                                    <option value="Masculino">Masculino</option>
                                                    <option value="Femenino">Femenino</option>
                                                    <option value="Otro">Otro</option>
                                                    <option value="Prefiero no decirlo">Prefiero no decirlo</option>
                                                </select>
                                                <span asp-validation-for="Genero" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label class="fw-semibold">Intereses</label>
                                                <textarea asp-for="Intereses"
                                                          class="form-control"
                                                          rows="3"
                                                          placeholder="Ej: Deportes, música, viajes, conversación, amistad..."></textarea>
                                                <span asp-validation-for="Intereses" class="text-danger"></span>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-semibold">Contraseña</label>
                                                <input asp-for="Clave" type="password" class="form-control" placeholder="Crea una contraseña segura" />
                                                <span asp-validation-for="Clave" class="text-danger"></span>
                                            </div>

                                            <div class="mt-4 text-end">
                                                <button class="btn btn-primary w-md waves-effect waves-light" type="submit">
                                                    Registrarme
                                                </button>
                                            </div>

                                            <div class="mt-4 text-center">
                                                <p class="mb-0 text-muted">
                                                    Al registrarte aceptas los
                                                    <a href="#" class="text-primary fw-semibold text-decoration-underline">
                                                        Términos y Condiciones
                                                    </a>
                                                    de ConociendoAmistades.cl
                                                </p>
                                            </div>
                                        </form>

                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <img src="~/assets/images/CA_CL_LOGO_V1.png"
                                     class="img-fluid mx-auto d-block"
                                     alt="Conociendo Amistades">
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 text-center">
                        <p>
                            ¿Ya tienes una cuenta?
                            <a href="@Url.Action("Login", "Authentication")"
                               class="fw-semibold text-decoration-underline">
                                Inicia sesión
                            </a>
                        </p>
                        <p>
                            © <script>document.write(new Date().getFullYear())</script>
                            <b>ConociendoAmistades.cl</b>. Hecho con
                            <i class="mdi mdi-heart text-danger"></i>
                            en Chile
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>

    @Html.Partial("~/Views/Shared/_vendor_scripts.cshtml")
</body>
</html>